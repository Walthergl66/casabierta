# ─────────────────────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Origen del frontend permitido por CORS (separar con comas si hay varios)
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────
# Supabase — Panel > Project Settings > Database / API
# ─────────────────────────────────────────────────────────────
# Usa la cadena del "Connection Pooler" (puerto 6543) en producción.
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Conexión directa (puerto 5432), necesaria solo para ejecutar migraciones.
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

SUPABASE_URL="https://[REF].supabase.co"
# ¡SECRETO! Service role key: nunca la expongas al frontend.
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET=images

# ─────────────────────────────────────────────────────────────
# Redis (BullMQ) — local vía docker compose; en producción, Upstash
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# Proveedor de imágenes (texto -> imagen)
# Valores: pollinations | openai | google | flux | stability
# pollinations es el único que NO necesita API key.
# ─────────────────────────────────────────────────────────────
IMAGE_PROVIDER=pollinations

# ─────────────────────────────────────────────────────────────
# Proveedor de edición (foto -> imagen). Es la función de CÁMARA.
# Valores: none | openai
#
# Va aparte de IMAGE_PROVIDER a propósito: Pollinations es gratis pero NO sabe
# editar fotos (comprobado: ignora la imagen de entrada y devuelve algo sin
# relación). Así los prompts de texto siguen saliendo gratis y solo las fotos
# cuestan dinero.
#
# Con "none" la pestaña de cámara se oculta en el frontend.
# Con "openai" hace falta OPENAI_API_KEY. Coste aprox: 0,02-0,19 $ por foto.
# ─────────────────────────────────────────────────────────────
IMAGE_EDIT_PROVIDER=none

OPENAI_API_KEY=""
GOOGLE_API_KEY=""
FLUX_API_KEY=""
STABILITY_API_KEY=""

# ─────────────────────────────────────────────────────────────
# Mejorador de prompt (LLM)
# Valores: none | openai | anthropic
# Con "none" se aplica una mejora heurística local, sin coste ni API key.
# ─────────────────────────────────────────────────────────────
PROMPT_ENHANCER=none
ANTHROPIC_API_KEY=""
